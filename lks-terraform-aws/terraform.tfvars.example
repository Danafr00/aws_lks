# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored – never commit secrets.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  LEARNING / TESTING MODE (default)                                      │
# │  - RDS open to internet, no backups, no deletion protection             │
# │  - All paid features disabled (WAF, KMS, ElastiCache, Multi-AZ)        │
# │  - Estimated cost: ~$0–5/month (NAT Gateway is the only paid item)      │
# │                                                                         │
# │  For LKS extra points, flip the paid feature flags below to true.       │
# └─────────────────────────────────────────────────────────────────────────┘

aws_region   = "ap-southeast-1"
project_name = "lks-app"
environment  = "development"

# ─── Networking ───────────────────────────────────────────────────────────────
vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["ap-southeast-1a", "ap-southeast-1b"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]
db_subnet_cidrs      = ["10.0.21.0/24", "10.0.22.0/24"]
single_nat_gateway   = true   # 1 NAT GW ~$32/month (false = 2 GWs, full HA)

# ─── Compute ──────────────────────────────────────────────────────────────────
instance_type         = "t2.micro"   # free tier
bastion_instance_type = "t2.micro"   # free tier
key_pair_name         = ""           # set to your key pair name for SSH

min_capacity     = 1
max_capacity     = 2
desired_capacity = 1

# ─── Database ─────────────────────────────────────────────────────────────────
db_availability_zone       = "ap-southeast-1a"   # pin to 1 AZ
db_instance_class          = "db.t3.micro"        # free tier
db_name                    = "lksapp"
db_username                = "dbadmin"             # password auto-generated, stored in Secrets Manager
db_allocated_storage       = 20                    # free tier max
db_max_allocated_storage   = 20                    # equal = disable autoscaling
db_backup_retention_period = 0                     # 0 = no automated backups (learning default)

rds_open_ingress        = true    # open port 3306 to 0.0.0.0/0 (learning only)
rds_publicly_accessible = true    # reachable from internet (learning only)

# EXTRA POINTS: flip to true
enable_multi_az     = false
enable_read_replica = false

# ─── Cache ────────────────────────────────────────────────────────────────────
# EXTRA POINTS: flip to true (~$12+/month)
enable_elasticache       = false
redis_node_type          = "cache.t3.micro"
redis_num_shards         = 1
redis_replicas_per_shard = 0

# ─── WAF (~$5/month) ──────────────────────────────────────────────────────────
# EXTRA POINTS: flip to true
enable_waf = false

# ─── KMS CMK ($1/key/month) ───────────────────────────────────────────────────
# EXTRA POINTS: flip to true
enable_kms_cmk = false

# ─── Domain / SSL ─────────────────────────────────────────────────────────────
domain_name                = ""   # leave empty → use ALB DNS directly
cloudfront_certificate_arn = ""   # ACM cert ARN in us-east-1 for CloudFront custom domain

# ─── Monitoring ───────────────────────────────────────────────────────────────
alert_email = "your@email.com"

# ─── Safety ───────────────────────────────────────────────────────────────────
enable_deletion_protection = false   # keep false so terraform destroy works cleanly
