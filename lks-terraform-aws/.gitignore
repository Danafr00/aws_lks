.terraform.lock.hcl

# Variables file (contains sensitive values)
terraform.tfvars

# Plan files
*.tfplan
tfplan

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# SSH keys
*.pem
*.ppk

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
