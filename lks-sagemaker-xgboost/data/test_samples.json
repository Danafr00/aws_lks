{
  "description": "Test cases for the Loan Risk UI. Enter these values manually to verify the model.",
  "feature_order": ["age", "annual_income", "loan_amount", "loan_term_months", "credit_score", "employment_years", "debt_to_income_ratio", "has_mortgage", "num_credit_lines", "num_late_payments"],
  "test_cases": [
    {
      "name": "Low Risk — Stable Professional",
      "description": "Mid-career professional, strong credit, low debt burden",
      "inputs": {
        "age": 42,
        "annual_income": 85000,
        "loan_amount": 12000,
        "loan_term_months": 36,
        "credit_score": 720,
        "employment_years": 12,
        "debt_to_income_ratio": 0.22,
        "has_mortgage": 1,
        "num_credit_lines": 3,
        "num_late_payments": 0
      },
      "csv_payload": "42,85000,12000,36,720,12,0.22,1,3,0",
      "expected_risk": "LOW",
      "expected_decision": "Approved"
    },
    {
      "name": "High Risk — Unstable Borrower",
      "description": "Young borrower, poor credit score, high DTI, multiple late payments",
      "inputs": {
        "age": 26,
        "annual_income": 32000,
        "loan_amount": 20000,
        "loan_term_months": 60,
        "credit_score": 545,
        "employment_years": 1,
        "debt_to_income_ratio": 0.58,
        "has_mortgage": 0,
        "num_credit_lines": 8,
        "num_late_payments": 5
      },
      "csv_payload": "26,32000,20000,60,545,1,0.58,0,8,5",
      "expected_risk": "HIGH",
      "expected_decision": "Rejected"
    },
    {
      "name": "Medium Risk — Building Career",
      "description": "Young professional with moderate income and fair credit history",
      "inputs": {
        "age": 29,
        "annual_income": 50000,
        "loan_amount": 18000,
        "loan_term_months": 48,
        "credit_score": 625,
        "employment_years": 3,
        "debt_to_income_ratio": 0.38,
        "has_mortgage": 0,
        "num_credit_lines": 6,
        "num_late_payments": 2
      },
      "csv_payload": "29,50000,18000,48,625,3,0.38,0,6,2",
      "expected_risk": "MEDIUM",
      "expected_decision": "Conditional Approval"
    },
    {
      "name": "Edge Case — Senior, High Income, High Loan",
      "description": "Older borrower with excellent credit but large loan amount",
      "inputs": {
        "age": 58,
        "annual_income": 145000,
        "loan_amount": 40000,
        "loan_term_months": 36,
        "credit_score": 800,
        "employment_years": 28,
        "debt_to_income_ratio": 0.12,
        "has_mortgage": 1,
        "num_credit_lines": 2,
        "num_late_payments": 0
      },
      "csv_payload": "58,145000,40000,36,800,28,0.12,1,2,0",
      "expected_risk": "LOW",
      "expected_decision": "Approved"
    }
  ]
}
