<mxfile host="app.diagrams.net">
  <diagram name="AWS Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- User -->
        <mxCell id="user" value="User" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="100" y="300" width="80" height="80" as="geometry"/>
        </mxCell>

        <!-- Amplify -->
        <mxCell id="amplify" value="AWS Amplify&#xa;(Frontend Hosting)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="250" y="280" width="160" height="100" as="geometry"/>
        </mxCell>

        <!-- API Gateway -->
        <mxCell id="api" value="API Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="450" y="280" width="140" height="100" as="geometry"/>
        </mxCell>

        <!-- Lambda Insert -->
        <mxCell id="lambda1" value="Lambda&#xa;(Insert Visitor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="630" y="200" width="160" height="100" as="geometry"/>
        </mxCell>

        <!-- Lambda Summary -->
        <mxCell id="lambda2" value="Lambda&#xa;(Daily Summary)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="630" y="400" width="160" height="100" as="geometry"/>
        </mxCell>

        <!-- RDS -->
        <mxCell id="rds" value="Amazon RDS&#xa;(Database)" style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="850" y="280" width="140" height="120" as="geometry"/>
        </mxCell>

        <!-- EventBridge -->
        <mxCell id="eventbridge" value="EventBridge&#xa;(Scheduler)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="450" y="420" width="140" height="100" as="geometry"/>
        </mxCell>

        <!-- Backup -->
        <mxCell id="backup" value="AWS Backup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;" vertex="1" parent="1">
          <mxGeometry x="1050" y="280" width="140" height="100" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell id="e1" edge="1" parent="1" source="user" target="amplify" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="amplify" target="api" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="api" target="lambda1" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="lambda1" target="rds" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="eventbridge" target="lambda2" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" edge="1" parent="1" source="lambda2" target="rds" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" edge="1" parent="1" source="rds" target="backup" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>